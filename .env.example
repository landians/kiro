RUNTIME_ENV=local
SERVICE_NAME=kiro
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
LOG_FORMAT=pretty
LOG_FILTER=info

POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/kiro
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_MIN_CONNECTIONS=1
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
POSTGRES_ACQUIRE_TIMEOUT_SECONDS=5
POSTGRES_RUN_MIGRATIONS=true

REDIS_URL=redis://127.0.0.1:6379
REDIS_CONNECT_TIMEOUT_SECONDS=3
REDIS_KEY_PREFIX=kiro:local

JWT_ISSUER=kiro
JWT_AUDIENCE=kiro-api
JWT_SIGNING_KEY=replace_with_a_long_random_secret_key
JWT_ACCESS_TOKEN_TTL_SECONDS=7200
JWT_REFRESH_TOKEN_TTL_SECONDS=1296000
BLACKLIST_MODE=redis

GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USER_INFO_URL=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_HTTP_TIMEOUT_SECONDS=10
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
